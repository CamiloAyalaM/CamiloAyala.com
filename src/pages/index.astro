---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import BlogCard from '../components/BlogCard.astro';
import { getFeaturedPosts } from '../data/blog';
import { portfolioProjects, services, clients, credentials, highlights, certifications, aboutTags } from '../data/portfolio';

const featuredPosts = getFeaturedPosts().slice(0, 3);
const featuredProjects = portfolioProjects.filter(p => p.featured);
---

<BaseLayout
  title="Camilo Ayala Monje — Diseño Estratégico, Marketing & Comunicación Digital"
  description="Diseñador estratégico, profesor e investigador en diseño, marketing, tecnología, humanidades y comunicación digital. 12+ años creando experiencias que conectan marcas, instituciones y personas. Bogotá, Colombia."
  image="/assets/img/camilo-photo.jpg"
>
  <Navigation />

  <!-- HERO -->
  <section class="hero" id="inicio">
    <div class="noise"></div>
    <div class="hero-left">
      <div class="eyebrow">
        <span class="ey-dash"></span>
        <span class="ey-txt">Bogotá · Colombia</span>
      </div>
      <h1 class="h1">
        Donde el <em>diseño</em><br>
        se convierte<br>
        en <em>experiencia.</em>
      </h1>
      <p class="hero-desc">
        <strong>Diseñador estratégico, profesor e investigador</strong> en diseño, marketing,
        tecnología, humanidades y comunicación digital. Más de 12 años creando experiencias
        que conectan marcas, instituciones y personas.
      </p>
      <div class="hero-btns">
        <a href="#contacto" class="btn-g">Hablemos &rarr;</a>
        <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="btn-o">
          <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Seguir en LinkedIn
        </a>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-photo"></div>
      <div class="hero-badge">
        <div class="b-label">Ponente Internacional</div>
        <div class="b-val">ECADE2022 · Oporto</div>
        <div class="b-sub">Diseño generativo e IA</div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="mq-wrap" aria-hidden="true">
    <div class="mq-track">
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Diseño Estratégico</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Comunicación Digital</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Personal Branding</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">SEO &amp; SEM</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Diseño Generativo</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">UX / UI</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">CRM &amp; Salesforce</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Design Thinking</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Docencia Universitaria</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">IA Aplicada al Diseño</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Análisis de Datos</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Humanidades Digitales</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Marketing Digital</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Branding Editorial</span></div>
      <!-- duplicate for seamless loop -->
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Diseño Estratégico</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Comunicación Digital</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Personal Branding</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">SEO &amp; SEM</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Diseño Generativo</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">UX / UI</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">CRM &amp; Salesforce</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Design Thinking</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Docencia Universitaria</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">IA Aplicada al Diseño</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Análisis de Datos</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Humanidades Digitales</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Marketing Digital</span></div>
      <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Branding Editorial</span></div>
    </div>
  </div>

  <!-- HIGHLIGHTS -->
  <div class="highlights">
    {highlights.map((h, i) => (
      <div class="hl rv" style={`transition-delay: ${i * 0.09}s`}>
        <div class="hl-n">{h.number}</div>
        <div class="hl-l">{h.label}</div>
      </div>
    ))}
  </div>

  <!-- ABOUT -->
  <section class="about-sec" id="sobre">
    <div class="about-l rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Sobre mí</span></div>
      <h2 class="sec">Pasión por el diseño,<br>la <em>tecnología</em><br>y la comunicación.</h2>
      <div class="about-copy">
        <p>Soy Camilo Ayala Monje, bogotano, apasionado por el <strong>diseño, la tecnología y la comunicación</strong>. Experto en mercadeo y comunicación en educación, empresa privada y sector público.</p>
        <p>Mi trabajo integra <strong>Design Thinking, UX/UI, estrategias de comunicación digital, SEM, SEO, CRM</strong> y análisis de datos. <em>Magíster en Diseño</em> con enfoque en mercadeo y estudios en Humanidades Digitales por la Universidad de los Andes.</p>
        <p>Me caracterizan el <strong>liderazgo adaptativo</strong>, la comunicación asertiva y la creatividad. Diseño experiencias memorables que impactan positivamente a las personas y las organizaciones.</p>
      </div>
      <div class="atags">
        {aboutTags.map(tag => <span class="atag">{tag}</span>)}
      </div>
    </div>
    <div class="about-r rv">
      {credentials.map(c => (
        <div class="cred">
          <span class="cred-n">{c.number}</span>
          <div>
            <div class="cred-t">{c.title}</div>
            <div class="cred-s">{c.subtitle}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="edu-sec" id="educacion">
    <div class="edu-top">
      <div class="s-tag rv"><div class="s-line"></div><span class="s-txt">Formación &amp; Autoridad</span></div>
      <h2 class="sec rv" style="transition-delay:.06s">Educación &amp; <em>certificaciones.</em></h2>
    </div>
    <div class="edu-grid">
      <div class="edu-card rv" style="transition-delay:.08s">
        <div class="edu-yr">2019 – 2021</div>
        <div class="edu-deg">Magíster en Diseño</div>
        <div class="edu-sch">Universidad de los Andes · Bogotá</div>
        <div class="edu-desc">Enfoque en mercadeo y co-creación computacional. Investigación sobre diseño generativo e IA. Intersección entre tecnología, humanidades digitales y diseño. Archivos digitales y colecciones.</div>
        <span class="edu-badge">Titulado</span>
      </div>
      <div class="edu-card rv" style="transition-delay:.15s">
        <div class="edu-yr">2004 – 2009</div>
        <div class="edu-deg">Diseño Gráfico — B.F.A.</div>
        <div class="edu-sch">Universidad Jorge Tadeo Lozano · Bogotá</div>
        <div class="edu-desc">Formación de base en diseño visual, comunicación, tipografía y producción gráfica. Fundamento para una práctica profesional rigurosa y multidisciplinar.</div>
        <span class="edu-badge">Titulado</span>
      </div>
    </div>
    <div class="certs-block rv" style="transition-delay:.2s">
      <div class="certs-hd">Certificaciones &amp; educación continua</div>
      <div class="certs-wrap">
        {certifications.map(cert => (
          <div class="cert">
            <span class="cert-name">{cert.name}</span>
            <span class="cert-meta">{cert.issuer} · {cert.year}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="portfolio-sec" id="portafolio">
    <div class="port-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Portafolio</span></div>
        <h2 class="sec">Proyectos<br>con <em>impacto.</em></h2>
      </div>
      <p class="port-intro rv">Selección de campañas, investigaciones y proyectos de diseño estratégico con resultados medibles. Pasa el cursor sobre cada proyecto para ver descripción y métricas.</p>
    </div>
    <div class="port-grid">
      {featuredProjects.map((project, i) => (
        <div class={`pc rv pc-${project.gridSize}`} style={`transition-delay: ${i * 0.06}s`}>
          <div class="pc-img">
            <div class="pc-bg" style={`background-image: url('${project.image}')`}></div>
            <div class="pc-over">
              <div class="pc-cat">{project.category}</div>
              <div class="pc-title">{project.title}</div>
              <div class="pc-client">{project.client}</div>
            </div>
          </div>
          <div class="pc-desc">
            <div class="pc-metric">{project.metrics}</div>
            <div class="pc-role">{project.description}</div>
            <div class="pc-date">{project.client} · {project.year}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CLIENTS -->
  <div class="clients-sec">
    <div class="cl-hd rv">Organizaciones con las que he trabajado</div>
    <div class="cl-grid">
      {clients.map((client, i) => (
        <div class="cl-item rv" style={`transition-delay: ${i * 0.04}s`}>
          <div class="cl-logo" style={`background: ${client.bg}`}>
            <img src={client.logo} alt={client.name} loading="lazy" style={client.scale ? `transform: scale(${client.scale})` : ''} />
          </div>
          <span class="cl-name">{client.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- BLOG -->
  <section class="li-sec" id="blog">
    <div class="li-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Blog</span></div>
        <h2 class="sec">Últimas<br><em>publicaciones.</em></h2>
      </div>
      <p class="li-intro rv">Reflexiones sobre diseño estratégico, educación, tecnología e IA. Sígueme en <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">linkedin.com/in/camiloayalam</a> — 5K seguidores y creciendo.</p>
    </div>
    <div class="li-grid">
      {featuredPosts.map((post, i) => (
        <div class="li-card-wrap rv" style={`transition-delay: ${i * 0.09}s`}>
          <BlogCard {...post} />
        </div>
      ))}
    </div>
    <div class="li-banner rv" style="transition-delay:.12s">
      <div class="li-banner-t">
        <h3>¿Hablamos de diseño, tecnología y comunicación?</h3>
        <p>5.000 profesionales ya siguen esta conversación.</p>
      </div>
      <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="li-banner-a">
        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Seguir en LinkedIn
      </a>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-sec" id="servicios">
    <div class="srv-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Servicios</span></div>
        <h2 class="sec dk">Lo que puedo<br>hacer por <em>ti.</em></h2>
      </div>
      <p class="srv-intro rv">Combino visión estratégica, expertise en diseño y herramientas de IA para ayudar a organizaciones y profesionales a comunicar con autoridad y crecer con intención.</p>
    </div>
    <div class="srv-grid">
      {services.map((srv, i) => (
        <div class="srv-card rv" style={`transition-delay: ${i * 0.07}s`}>
          <div class="srv-n">{srv.number}</div>
          <div class="srv-title">{srv.title}</div>
          <div class="srv-desc">{srv.description}</div>
          <div class="srv-tags">
            {srv.tags.map(tag => <span class="srv-tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA / CONTACT -->
  <section class="cta-sec" id="contacto">
    <div class="cta-l rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Contacto</span></div>
      <h2 class="sec">Trabajemos<br><em>juntos.</em></h2>
      <p class="cta-body">Estoy disponible para consultoría, proyectos de diseño estratégico, marketing digital y talleres formativos. Hablemos sobre tu próximo proyecto.</p>
    </div>
    <div class="cta-r rv">
      <div class="cta-links">
        <a href="mailto:camiloayalamonje@gmail.com" class="cta-link">
          <span>Email directo</span>
          <div class="cta-meta">
            <span class="cta-badge">Disponible</span>
            <span class="cta-arr">&rarr;</span>
          </div>
        </a>
        <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="cta-link">
          <span>LinkedIn</span>
          <div class="cta-meta">
            <span class="cta-badge">5K+</span>
            <span class="cta-arr">&rarr;</span>
          </div>
        </a>
        <a href="https://behance.net/camiloayala" target="_blank" rel="noopener" class="cta-link">
          <span>Behance</span>
          <div class="cta-meta">
            <span class="cta-arr">&rarr;</span>
          </div>
        </a>
        <a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener" class="cta-link">
          <span>ORCID</span>
          <div class="cta-meta">
            <span class="cta-arr">&rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <a href="/" class="f-logo"><img src="/assets/img/camilo-ayala.webp" alt="Camilo Ayala" /></a>
    <p class="f-copy">&copy; 2025 Camilo Ayala Monje &middot; Bogotá, Colombia</p>
    <ul class="f-links">
      <li><a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">LinkedIn</a></li>
      <li><a href="https://behance.net/camiloayala" target="_blank" rel="noopener">Behance</a></li>
      <li><a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener">ORCID</a></li>
    </ul>
  </footer>

  <style is:global>
    /* ============================================
       SHARED SECTION ELEMENTS
    ============================================ */
    .s-tag {
      display: flex;
      align-items: center;
      gap: 11px;
      margin-bottom: 16px;
    }
    .s-line { width: 22px; height: 1px; background: var(--gold); }
    .s-txt {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .sec {
      font-family: var(--serif);
      font-size: clamp(32px, 3.9vw, 54px);
      font-weight: 400;
      line-height: 1.04;
      letter-spacing: -.012em;
      color: var(--fg);
    }
    .sec em { font-style: italic; font-weight: 600; color: var(--gold); }
    .sec.dk { color: rgba(244,240,232,.97); }
    .sec.dk em { color: var(--gold); }

    /* ============================================
       MARQUEE — dark themed
    ============================================ */
    .mq-wrap {
      border-top: 1px solid var(--dline);
      border-bottom: 1px solid var(--dline);
      padding: 15px 0;
      overflow: hidden;
      background: var(--ink);
      position: relative;
      z-index: 5;
    }
    .mq-track {
      display: flex;
      width: max-content;
      animation: scroll-mq 40s linear infinite;
      will-change: transform;
    }
    .mq-item {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 0 36px;
      white-space: nowrap;
    }
    .mq-dot {
      width: 3px;
      height: 3px;
      background: var(--gold);
      border-radius: 50%;
      flex-shrink: 0;
      opacity: .7;
    }
    .mq-txt {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: rgba(140,130,118,.5);
    }

    /* ============================================
       HIGHLIGHTS — gold strip
    ============================================ */
    .highlights {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: var(--gold);
    }
    .hl {
      padding: 54px 38px;
      text-align: center;
      border-right: 1px solid rgba(13,11,9,.12);
    }
    .hl:last-child { border-right: none; }
    .hl-n {
      font-family: var(--serif);
      font-size: clamp(40px, 4.4vw, 64px);
      font-weight: 700;
      color: var(--ink);
      line-height: 1;
    }
    .hl-n sup { font-size: .45em; vertical-align: super; }
    .hl-l {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(13,11,9,.45);
      margin-top: 10px;
      line-height: 1.5;
      white-space: pre-line;
    }

    /* ============================================
       ABOUT
    ============================================ */
    .about-sec {
      padding: 124px var(--edge);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 88px;
      align-items: start;
      background: var(--cream);
    }
    .about-copy {
      font-size: 15.5px;
      line-height: 1.9;
      color: var(--fg2);
      margin-top: 28px;
      max-width: 470px;
    }
    .about-copy p + p { margin-top: 20px; }
    .about-copy strong { color: var(--fg); font-weight: 600; }
    .about-copy em { font-style: normal; color: var(--gold); font-weight: 600; }
    .atags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 30px;
    }
    .atag {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold25);
      padding: 6px 13px;
      transition: background .2s, border-color .2s;
      cursor: default;
    }
    .atag:hover { background: var(--gold08); border-color: var(--gold); }
    .cred {
      display: flex;
      gap: 18px;
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
    }
    .cred:first-child { border-top: 1px solid var(--line); }
    .cred-n {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--gold);
      padding-top: 2px;
      min-width: 22px;
      flex-shrink: 0;
    }
    .cred-t { font-size: 14px; font-weight: 600; color: var(--fg); margin-bottom: 3px; line-height: 1.3; }
    .cred-s { font-size: 12.5px; color: var(--muted); line-height: 1.6; }

    /* ============================================
       EDUCATION
    ============================================ */
    .edu-sec {
      padding: 0 var(--edge) 128px;
      background: var(--cream);
    }
    .edu-top {
      border-top: 1px solid var(--line);
      padding-top: 68px;
      margin-bottom: 52px;
    }
    .edu-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--line);
    }
    .edu-card {
      background: var(--cream);
      padding: 36px 32px;
      position: relative;
      overflow: hidden;
      transition: background .28s;
    }
    .edu-card:hover { background: var(--warm); }
    .edu-card::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .42s ease;
    }
    .edu-card:hover::after { transform: scaleX(1); }
    .edu-yr {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .15em;
      color: var(--gold);
      margin-bottom: 13px;
    }
    .edu-deg {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 600;
      color: var(--fg);
      line-height: 1.22;
      margin-bottom: 5px;
    }
    .edu-sch {
      font-family: var(--mono);
      font-size: 10px;
