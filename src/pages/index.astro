    /* ============================================
       RESPONSIVE — sections
    ============================================ */
    @media (max-width: 1140px) {
      .about-sec, .edu-sec, .portfolio-sec, .clients-sec,
      .li-sec, .services-sec, .cta-sec { padding-left: 32px; padding-right: 32px; }
    }

    @media (max-width: 1024px) {
      .highlights { grid-template-columns: repeat(2, 1fr); }
      .hl:nth-child(even) { border-right: none; }
      .hl:nth-child(n+3) { border-top: 1px solid rgba(13,11,9,.12); }
      .about-sec { grid-template-columns: 1fr; gap: 52px; }
      .edu-grid { grid-template-columns: 1fr; }
      .port-head, .srv-head, .li-head { grid-template-columns: 1fr; gap: 24px; }
      .cl-grid { grid-template-columns: repeat(5, 1fr); }
      .srv-grid { grid-template-columns: repeat(2, 1fr); }
      .li-grid { grid-template-columns: repeat(2, 1fr); }
      .cta-sec { grid-template-columns: 1fr; gap: 40px; }
    }

    @media (max-width: 768px) {
      .about-sec, .portfolio-sec, .clients-sec,
      .li-sec, .services-sec { padding: 80px 20px; }
      .edu-sec { padding: 0 20px 80px; }
      .cta-sec { padding: 80px 20px; }
      .highlights { grid-template-columns: repeat(2, 1fr); }
      .port-grid { grid-template-columns: 1fr; }
      .pc-lg, .pc-sm, .pc-md { grid-column: span 1; }
      .li-grid { grid-template-columns: 1fr; }
      .li-banner { flex-direction: column; align-items: flex-start; }
      .cl-grid { grid-template-columns: repeat(2, 1fr); }
      .srv-grid { grid-template-columns: 1fr; }
      .footer { flex-direction: column; gap: 16px; text-align: center; padding: 28px 20px; }
    }
  </style>

  <script>
    // Intersection Observer — reveal on scroll
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.rv, .rv-l').forEach(el => revealObs.observe(el));
  </script>
</BaseLayout>
