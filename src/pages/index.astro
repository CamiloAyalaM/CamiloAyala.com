      font-size: 12px;
      color: var(--muted);
      transition: color .22s, transform .28s;
    }
    .cta-link:hover .cta-arr { color: var(--gold); transform: translateX(5px); }

    /* ============================================
       FOOTER
    ============================================ */
    .footer {
      padding: 36px var(--edge);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--ink);
      border-top: 1px solid var(--dline);
    }
    .f-logo img { height: 22px; filter: invert(1) brightness(1) opacity(.36); transition: filter .22s; }
    .f-logo:hover img { filter: invert(1) brightness(1) opacity(.7); }
    .f-copy { font-family: var(--mono); font-size: 10px; color: rgba(140,130,118,.32); letter-spacing: .05em; }
    .f-links { display: flex; gap: 26px; list-style: none; }
    .f-links a {
