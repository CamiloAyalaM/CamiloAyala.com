---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import BlogCard from '../components/BlogCard.astro';
import { getFeaturedPosts } from '../data/blog';
import { portfolioProjects, services, clients, credentials, highlights, skillCategories } from '../data/portfolio';

const featuredPosts = getFeaturedPosts().slice(0, 3);
const featuredProjects = portfolioProjects.filter(p => p.featured);
---

<BaseLayout
  title="Camilo Ayala Monje — Diseño Estratégico, Marketing & Comunicación Digital"
  description="Diseñador estratégico, profesor e investigador en diseño, marketing, tecnología, humanidades y comunicación digital. 12+ años creando experiencias que conectan marcas, instituciones y personas. Bogotá, Colombia."
  image="/assets/img/camilo-photo.jpg"
>
  <Navigation />

  <!-- HERO -->
  <section class="hero" id="inicio">
    <div class="hero-bg">
      <div class="hero-grain"></div>
      <div class="hero-lines"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-txt">Bogotá, Colombia · Disponible para proyectos</span>
        </div>
        <h1 class="hero-title">
          <span class="ht-row"><span class="ht-mask"><span class="ht-word">Camilo</span></span></span>
          <span class="ht-row"><span class="ht-mask"><span class="ht-word">Ayala</span></span></span>
          <span class="ht-row"><span class="ht-mask italic"><span class="ht-word">Monje</span></span></span>
        </h1>
        <div class="hero-role">
          <span class="role-item">Diseño Estratégico</span>
          <span class="role-sep">·</span>
          <span class="role-item">Marketing</span>
          <span class="role-sep">·</span>
          <span class="role-item">Comunicación Digital</span>
        </div>
        <p class="hero-desc">
          Diseñador, académico e investigador. 12+ años creando experiencias que conectan marcas, instituciones y personas. Investigación sobre IA, diseño generativo y humanidades digitales.
        </p>
        <div class="hero-actions">
          <a href="#portafolio" class="btn-p">Ver trabajo</a>
          <a href="#contacto" class="btn-g">Hablemos →</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-img-wrap">
          <img src="/assets/img/camilo-photo.jpg" alt="Camilo Ayala Monje" class="hero-img" />
          <div class="hero-img-accent"></div>
          <div class="hero-badge">
            <span class="badge-num">12+</span>
            <span class="badge-lbl">años<br>experiencia</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span class="scroll-line"></span>
      <span class="scroll-txt">scroll</span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="mq-wrap">
    <div class="mq-track">
      <span>Diseño Estratégico</span><span class="mq-dot">◆</span>
      <span>Marketing Digital</span><span class="mq-dot">◆</span>
      <span>UX / UI</span><span class="mq-dot">◆</span>
      <span>Diseño Generativo</span><span class="mq-dot">◆</span>
      <span>IA Aplicada</span><span class="mq-dot">◆</span>
      <span>Humanidades Digitales</span><span class="mq-dot">◆</span>
      <span>Personal Branding</span><span class="mq-dot">◆</span>
      <span>Investigación</span><span class="mq-dot">◆</span>
      <span>Docencia</span><span class="mq-dot">◆</span>
      <span>Design Thinking</span><span class="mq-dot">◆</span>
      <span>Diseño Estratégico</span><span class="mq-dot">◆</span>
      <span>Marketing Digital</span><span class="mq-dot">◆</span>
      <span>UX / UI</span><span class="mq-dot">◆</span>
      <span>Diseño Generativo</span><span class="mq-dot">◆</span>
      <span>IA Aplicada</span><span class="mq-dot">◆</span>
      <span>Humanidades Digitales</span><span class="mq-dot">◆</span>
      <span>Personal Branding</span><span class="mq-dot">◆</span>
      <span>Investigación</span><span class="mq-dot">◆</span>
      <span>Docencia</span><span class="mq-dot">◆</span>
      <span>Design Thinking</span><span class="mq-dot">◆</span>
    </div>
  </div>

  <!-- HIGHLIGHTS / STATS -->
  <section class="hl-sec">
    <div class="hl-grid">
      {highlights.map((h, i) => (
        <div class="hl-item rv" style={`transition-delay: ${i * 0.1}s`}>
          <div class="hl-num">{h.number}</div>
          <div class="hl-lbl">{h.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-sec" id="sobre">
    <div class="about-inner">
      <div class="about-l rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Sobre mí</span></div>
        <h2 class="sec">Diseño que piensa.<br><em>Estrategia que conecta.</em></h2>
        <p class="about-p">Soy diseñador estratégico, profesor universitario e investigador en la intersección del diseño, la tecnología y las humanidades digitales. Durante más de 12 años he trabajado con marcas internacionales, instituciones educativas y proyectos de impacto social en Latinoamérica y el mundo.</p>
        <p class="about-p">Mi trabajo vincula el rigor académico con la ejecución creativa — desde campañas globales hasta sistemas de diseño participativo para comunidades de economía informal.</p>
        <div class="about-links">
          <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="about-link">LinkedIn</a>
          <a href="https://behance.net/camiloayala" target="_blank" rel="noopener" class="about-link">Behance</a>
          <a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener" class="about-link">ORCID</a>
        </div>
      </div>
      <div class="about-r rv">
        <div class="creds-list">
          {credentials.map((c, i) => (
            <div class="cred rv" style={`transition-delay: ${i * 0.08}s`}>
              <span class="cred-n">{c.number}</span>
              <div class="cred-body">
                <div class="cred-title">{c.title}</div>
                <div class="cred-sub">{c.subtitle}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- EDUCATION / ACADEMIC -->
  <section class="edu-sec" id="educacion">
    <div class="edu-inner">
      <div class="rv-l" style="margin-bottom: 64px;">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Formación</span></div>
        <h2 class="sec">Rigor académico<br>en el <em>mundo real.</em></h2>
      </div>
      <div class="edu-grid">
        <div class="edu-card rv">
          <div class="edu-year">2022</div>
          <div class="edu-inst">Universidad de Los Andes</div>
          <div class="edu-title">Magíster en Diseño</div>
          <div class="edu-desc">Énfasis en mercadeo y Humanidades Digitales. Investigación sobre diseño generativo, IA y co-creación en economía informal.</div>
        </div>
        <div class="edu-card rv" style="transition-delay: 0.1s">
          <div class="edu-year">2022</div>
          <div class="edu-inst">ECADE · Oporto, Portugal</div>
          <div class="edu-title">Ponente Internacional</div>
          <div class="edu-desc">Presentación peer-reviewed sobre diseño generativo como herramienta de co-creación. Publicación en actas internacionales.</div>
        </div>
        <div class="edu-card rv" style="transition-delay: 0.2s">
          <div class="edu-year">2009</div>
          <div class="edu-inst">Universidad de Los Andes</div>
          <div class="edu-title">Pregrado en Diseño</div>
          <div class="edu-desc">Formación en diseño estratégico, comunicación visual y sistemas de diseño. Base para 12+ años de práctica profesional.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="portfolio-sec" id="portafolio">
    <div class="port-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Portafolio</span></div>
        <h2 class="sec">Proyectos que<br>generan <em>impacto.</em></h2>
      </div>
      <p class="port-intro rv">Trabajo con marcas globales, instituciones educativas y proyectos de impacto social. Cada proyecto es un sistema — visual, estratégico y humano.</p>
    </div>
    <div class="pc-grid">
      {featuredProjects.map((project, i) => (
        <div class="pc rv" style={`transition-delay: ${i * 0.07}s`}>
          <div class="pc-vis">
            <div class="pc-img" style={`background-image: url('${project.image}')`}></div>
            <div class="pc-over">
              <div class="pc-cat">{project.category}</div>
              <div class="pc-title">{project.title}</div>
              <div class="pc-client">{project.client}</div>
            </div>
          </div>
          <div class="pc-desc">
            <div class="pc-metric">{project.metrics}</div>
            <div class="pc-role">{project.description}</div>
            <div class="pc-meta">{project.client} · {project.year}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CLIENTS -->
  <div class="clients-sec">
    <div class="cl-hd rv">Organizaciones con las que he trabajado</div>
    <div class="cl-grid">
      {clients.map((client, i) => (
        <div class="cl-item rv" style={`transition-delay: ${i * 0.05}s`}>
          <div class="cl-logo" style={`background: ${client.bg}`}>
            <img src={client.logo} alt={client.name} loading="lazy" />
          </div>
          <span class="cl-name">{client.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- SKILLS -->
  <section class="skills-sec">
    <div class="skills-inner">
      <div class="rv-l" style="margin-bottom: 64px;">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Capacidades</span></div>
        <h2 class="sec">Diseño, estrategia<br>y <em>tecnología.</em></h2>
      </div>
      <div class="sk-grid">
        {skillCategories.map((cat, i) => (
          <div class="sk-col rv" style={`transition-delay: ${i * 0.1}s`}>
            <div class="sk-cat">{cat.category}</div>
            <div class="sk-list">
              {cat.skills.map(skill => (
                <span class="atag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="li-sec" id="blog">
    <div class="li-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Blog</span></div>
        <h2 class="sec">Reflexiones sobre<br><em>diseño y tecnología.</em></h2>
      </div>
      <p class="li-intro rv">Artículos sobre diseño estratégico, educación, tecnología e IA. Sígueme en <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">LinkedIn</a> — 5K+ seguidores.</p>
    </div>
    <div class="li-grid">
      {featuredPosts.map((post, i) => (
        <div class="li-card-wrap rv" style={`transition-delay: ${i * 0.1}s`}>
          <BlogCard {...post} />
        </div>
      ))}
    </div>
    <div class="li-cta rv">
      <a href="/blog" class="btn-g">Ver todos los artículos →</a>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-sec" id="servicios">
    <div class="srv-head">
      <div class="rv-l">
        <div class="s-tag"><div class="s-line"></div><span class="s-txt">Servicios</span></div>
        <h2 class="sec dk">Lo que puedo<br>hacer por <em>ti.</em></h2>
      </div>
      <p class="srv-intro rv">Combino visión estratégica, expertise en diseño y herramientas de IA para ayudar a organizaciones y profesionales a comunicar con autoridad y crecer con intención.</p>
    </div>
    <div class="srv-grid">
      {services.map((srv, i) => (
        <div class="srv-card rv" style={`transition-delay: ${i * 0.07}s`}>
          <div class="srv-n">{srv.number}</div>
          <div class="srv-title">{srv.title}</div>
          <div class="srv-desc">{srv.description}</div>
          <div class="srv-tags">
            {srv.tags.map(tag => (
              <span class="srv-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA / CONTACT -->
  <section class="cta-sec" id="contacto">
    <div class="cta-inner">
      <div class="cta-content rv-l">
        <div class="s-tag" style="justify-content: center;"><div class="s-line"></div><span class="s-txt">Contacto</span></div>
        <h2 class="cta-title">¿Tienes un proyecto<br>en mente?</h2>
        <p class="cta-desc">Estoy disponible para consultoría, proyectos de diseño estratégico, marketing digital y talleres formativos. Hablemos.</p>
        <div class="cta-actions">
          <a href="mailto:camiloayalamonje@gmail.com" class="btn-p-light">camiloayalamonje@gmail.com</a>
          <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="btn-g-light">LinkedIn →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="foot-inner">
      <div class="foot-l">
        <img src="/assets/img/camilo-ayala.webp" alt="Camilo Ayala" class="foot-logo" />
        <p class="foot-copy">© 2025 Camilo Ayala Monje · Bogotá, Colombia</p>
      </div>
      <div class="foot-links">
        <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://behance.net/camiloayala" target="_blank" rel="noopener">Behance</a>
        <a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener">ORCID</a>
        <a href="/blog">Blog</a>
      </div>
    </div>
  </footer>

  <style is:global>
    /* ============================================
       HERO
    ============================================ */
    .hero {
      position: relative;
      min-height: 100vh;
      background: var(--ink);
      display: flex;
      flex-direction: column;
      justify-content: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-grain {
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 600 600' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.6;
    }

    .hero-lines {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(182, 144, 58, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(182, 144, 58, 0.04) 1px, transparent 1px);
      background-size: 80px 80px;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding: 120px var(--edge) 100px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
      opacity: 0;
      animation: f-up 0.6s ease 0.2s forwards;
    }

    .eyebrow-line {
      display: block;
      width: 24px;
      height: 1px;
      background: var(--gold);
    }

    .eyebrow-txt {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
    }

    .hero-title {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 24px;
    }

    .ht-row {
      display: block;
      overflow: hidden;
    }

    .ht-mask {
      display: block;
      transform: translateY(100%);
      animation: w-rise 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .ht-row:nth-child(1) .ht-mask { animation-delay: 0.3s; }
    .ht-row:nth-child(2) .ht-mask { animation-delay: 0.45s; }
    .ht-row:nth-child(3) .ht-mask { animation-delay: 0.6s; }

    .ht-word {
      display: block;
      font-family: var(--serif);
      font-size: clamp(56px, 8vw, 112px);
      font-weight: 400;
      line-height: 0.95;
      color: var(--cream);
      letter-spacing: -0.02em;
    }

    .ht-mask.italic .ht-word {
      font-style: italic;
      font-weight: 600;
      color: var(--gold);
    }

    .hero-role {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 28px;
      opacity: 0;
      animation: f-up 0.8s ease 0.9s forwards;
    }

    .role-item {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.15em;
      color: rgba(244, 240, 232, 0.45);
      text-transform: uppercase;
    }

    .role-sep {
      color: var(--gold);
      font-size: 10px;
    }

    .hero-desc {
      font-size: 15px;
      line-height: 1.8;
      color: rgba(244, 240, 232, 0.55);
      max-width: 480px;
      margin-bottom: 44px;
      opacity: 0;
      animation: f-up 0.8s ease 1.0s forwards;
    }

    .hero-actions {
      display: flex;
      gap: 16px;
      align-items: center;
      opacity: 0;
      animation: f-up 0.8s ease 1.1s forwards;
    }

    .btn-p {
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--gold);
      padding: 13px 28px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }

    .btn-p:hover {
      background: var(--goldt);
      transform: translateY(-1px);
    }

    .btn-g {
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(182, 144, 58, 0.3);
      padding-bottom: 2px;
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-g:hover {
      color: var(--goldt);
      border-color: var(--goldt);
    }

    /* Hero right / photo */
    .hero-right {
      display: flex;
      justify-content: center;
      opacity: 0;
      animation: f-up 1s ease 0.5s forwards;
    }

    .hero-img-wrap {
      position: relative;
      width: 380px;
    }

    .hero-img {
      width: 100%;
      height: 520px;
      object-fit: cover;
      object-position: top center;
      display: block;
      filter: grayscale(15%) contrast(1.05);
    }

    .hero-img-accent {
      position: absolute;
      bottom: -20px;
      right: -20px;
      width: 120px;
      height: 120px;
      border: 1px solid var(--gold);
      pointer-events: none;
    }

    .hero-badge {
      position: absolute;
      top: 24px;
      left: -20px;
      background: var(--gold);
      padding: 16px 20px;
      text-align: center;
    }

    .badge-num {
      display: block;
      font-family: var(--serif);
      font-size: 28px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1;
    }

    .badge-lbl {
      display: block;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.12em;
      color: var(--ink);
      text-transform: uppercase;
      margin-top: 4px;
    }

    .hero-scroll {
      position: absolute;
      bottom: 40px;
      left: var(--edge);
      display: flex;
      align-items: center;
      gap: 12px;
      opacity: 0;
      animation: f-up 0.8s ease 1.4s forwards;
    }

    .scroll-line {
      display: block;
      width: 1px;
      height: 40px;
      background: rgba(244, 240, 232, 0.2);
      position: relative;
      overflow: hidden;
    }

    .scroll-line::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 50%;
      background: var(--gold);
      animation: scroll-pulse 2s ease infinite;
    }

    @keyframes scroll-pulse {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(300%); }
    }

    .scroll-txt {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      color: rgba(244, 240, 232, 0.3);
      text-transform: uppercase;
      writing-mode: vertical-rl;
    }

    /* ============================================
       MARQUEE
    ============================================ */
    .mq-wrap {
      overflow: hidden;
      background: var(--gold);
      padding: 14px 0;
      white-space: nowrap;
    }

    .mq-track {
      display: inline-flex;
      gap: 28px;
      align-items: center;
      animation: scroll-mq 30s linear infinite;
      will-change: transform;
    }

    .mq-track span {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      white-space: nowrap;
    }

    .mq-dot {
      font-size: 6px !important;
      opacity: 0.5;
    }

    /* ============================================
       HIGHLIGHTS
    ============================================ */
    .hl-sec {
      padding: 80px var(--edge);
      background: var(--cream);
      border-bottom: 1px solid var(--line);
    }

    .hl-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }

    .hl-item {
      padding: 40px;
      border-right: 1px solid var(--line);
      text-align: center;
    }

    .hl-item:last-child {
      border-right: none;
    }

    .hl-num {
      font-family: var(--serif);
      font-size: 56px;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 8px;
    }

    .hl-lbl {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      white-space: pre-line;
    }

    /* ============================================
       SECTION TAGS
    ============================================ */
    .s-tag {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }

