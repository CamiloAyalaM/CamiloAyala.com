    .srv-desc { font-size: 13.5px; line-height: 1.8; color: rgba(140,130,118,.68); margin-bottom: 16px; }
    .srv-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .srv-tag {
      font-family: var(--mono);
      font-size: 8.5px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: rgba(182,144,58,.52);
