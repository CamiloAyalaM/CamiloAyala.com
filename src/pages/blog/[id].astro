---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import { getPostById, getAllPosts } from '../../data/blog';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const formattedDate = post.date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={`${post.title} — Blog`}
  description={post.excerpt}
>
  <Navigation />

  <article style="max-width: 800px; margin: 120px auto; padding: 0 20px; background: var(--cream); min-height: 100vh;">
    <div style="margin-bottom: 40px;">
      <h1 style="
        font-family: var(--serif);
        font-size: clamp(28px, 5vw, 48px);
        font-weight: 400;
        line-height: 1.1;
        margin-bottom: 20px;
        color: var(--fg);
      ">
        {post.title}
      </h1>

      <div style="
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        color: rgba(107, 99, 89, 0.8);
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 40px;
      ">
        <time>{formattedDate}</time>
        <span style="display: flex; gap: 8px; flex-wrap: wrap;">
          {post.tags.map((tag) => (
            <span style="background: rgba(182, 144, 58, 0.1); color: var(--gold); padding: 4px 8px; border-radius: 2px;">
              {tag}
            </span>
          ))}
        </span>
        <span style="margin-left: auto;">👍 {post.reactions}</span>
      </div>
    </div>

    <div class="post-content" set:html={post.content} style="
      line-height: 1.85;
      font-size: 16px;
      color: #2b2720;
    "></div>

    <div style="
      margin-top: 60px;
      padding-top: 40px;
      border-top: 1px solid rgba(13, 11, 9, 0.08);
    ">
      <a href="/blog" style="
        color: var(--gold);
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: gap 0.2s;
      ">
        ← Volver a artículos
      </a>
    </div>

    <section style="
      margin-top: 80px;
      padding-top: 60px;
      border-top: 1px solid rgba(13, 11, 9, 0.08);
    ">
      <h3 style="
        font-family: var(--serif);
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 30px;
        color: var(--fg);
      ">
        Más artículos
      </h3>
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 24px;
      ">
        {/* Aquí podrías mostrar posts relacionados o recientes */}
      </div>
    </section>
  </article>

  <style>
    .post-content :global(p) {
      margin-bottom: 1.5rem;
    }

    .post-content :global(strong) {
      font-weight: 700;
      color: var(--ink);
    }

    .post-content :global(em) {
      font-style: italic;
      color: var(--gold);
    }

    .post-content :global(h2) {
      font-family: var(--serif);
      font-size: 1.8rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-weight: 600;
      color: var(--fg);
    }

    .post-content :global(h3) {
      font-family: var(--serif);
      font-size: 1.4rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
      color: var(--fg);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      margin-left: 2rem;
      margin-bottom: 1.5rem;
    }

    .post-content :global(li) {
      margin-bottom: 0.75rem;
    }

    .post-content :global(blockquote) {
      border-left: 4px solid var(--gold);
      padding-left: 1.5rem;
      margin-left: 0;
      margin-bottom: 1.5rem;
      font-style: italic;
      color: rgba(107, 99, 89, 0.9);
    }

    .post-content :global(code) {
      background: rgba(182, 144, 58, 0.1);
      color: var(--gold);
      padding: 2px 6px;
      border-radius: 3px;
      font-family: var(--mono);
      font-size: 0.9em;
    }

    .post-content :global(pre) {
      background: #f4f0e8;
      padding: 1.5rem;
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 1.5rem;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.5;
    }

    .post-content :global(a) {
      color: var(--gold);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s;
    }

    .post-content :global(a:hover) {
      color: var(--goldt);
    }
  </style>
</BaseLayout>
