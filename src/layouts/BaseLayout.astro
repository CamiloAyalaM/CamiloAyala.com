---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = 'Camilo Ayala Monje — Ejecutivo Senior en Estrategia, Mercadeo y Transformación Digital',
  description = 'Ejecutivo senior en estrategia de marca, mercadeo y comunicación digital. Más de 12 años liderando posicionamiento institucional y transformación digital en educación superior, banca central y consultoría internacional. Profesor de posgrado en marketing e IA. Bogotá, Colombia.',
  image = '/assets/img/camilo-photo.jpg',
  url = 'https://camiloayala.com'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, url);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <script is:inline>if(!matchMedia('(prefers-reduced-motion: reduce)').matches)document.documentElement.classList.add('motion');</script>
  <meta name="description" content={description} />
  <meta name="keywords" content="estratega de marca, dirección de marketing, marketing educativo, admisiones, transformación digital, CRM, salesforce, IA, diseño generativo, UX/UI, conferencista, bogotá" />
  <meta name="author" content="Camilo Ayala Monje" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, url).toString()} />
  <meta property="og:site_name" content="Camilo Ayala Monje" />
  <meta property="og:locale" content="es_ES" />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL.toString()} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, url).toString()} />
  <meta property="twitter:creator" content="@camiloayalam" />
  
  <!-- LinkedIn -->
  <meta property="linkedin:title" content={title} />
  <meta property="linkedin:description" content={description} />
  
  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.toString()} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" /></noscript>

  <!-- LCP image preload -->
  <link rel="preload" as="image" href="/assets/img/camilo-photo.webp" fetchpriority="high" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/CA-logo-ico.png" />
  
  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Camilo Ayala Monje",
      "jobTitle": "Ejecutivo Senior en Estrategia de Marca, Mercadeo y Comunicación Digital",
      "award": "Ganador del concurso nacional de diseño de la moneda conmemorativa 90 años, Banco de la República (2015)",
      "url": "https://camiloayala.com",
      "image": "https://camiloayala.com/assets/img/camilo-photo.jpg",
      "sameAs": [
        "https://linkedin.com/in/camiloayalam",
        "https://behance.net/camiloayala",
        "https://orcid.org/0000-0002-3485-718X"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Universidad El Bosque"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressRegion": "DC",
        "addressCountry": "CO"
      },
      "email": "camiloayalamonje [at] gmail.com",
      "knowsAbout": [
        "Dirección Estratégica de Marca",
        "Marketing Digital",
        "Marketing Educativo y Admisiones",
        "Comunicación",
        "UX/UI",
        "CRM y Salesforce",
        "Analítica de Datos",
        "Diseño Generativo",
        "IA",
        "Docencia",
        "Design Thinking"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Camilo Ayala Monje — Estrategia, Diseño & Consultoría Ejecutiva",
      "url": "https://camiloayala.com",
      "image": "https://camiloayala.com/assets/img/camilo-photo.jpg",
      "email": "camiloayalamonje [at] gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressRegion": "Bogotá D.C.",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.7110,
        "longitude": -74.0721
      },
      "areaServed": ["Colombia", "Latinoamérica"],
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Estrategia, Diseño y Consultoría Ejecutiva",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dirección Estratégica de Marca", "description": "Posicionamiento institucional y arquitectura de marca para organizaciones que compiten por autoridad. Del diagnóstico al gobierno de marca." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Growth & Marketing Educativo", "description": "Captación y admisiones para instituciones educativas: embudos, experiencia del candidato y analítica." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transformación Digital & CRM", "description": "SEO, SEM, Salesforce y analítica de datos al servicio de KPIs de negocio." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "UX & Experiencia de Cliente", "description": "Auditorías, rediseños y design systems que alinean la experiencia digital con los objetivos del negocio." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "IA & Diseño Generativo", "description": "Adopción de IA en procesos creativos y de negocio, con respaldo académico e investigación publicada." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Conferencias & Formación Ejecutiva", "description": "Keynotes y workshops para comités directivos y equipos: estrategia, Design Thinking e IA aplicada." } }
        ]
      }
    }
  ]
  </script>
  
  <title>{title}</title>
</head>

<body>
  <slot />
</body>
</html>
