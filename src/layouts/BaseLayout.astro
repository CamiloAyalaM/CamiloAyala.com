---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = 'Camilo Ayala Monje — Ejecutivo Senior en Estrategia, Mercadeo y Transformación Digital',
  description = 'Ejecutivo senior en estrategia de marca, mercadeo y comunicación digital. Más de 12 años liderando posicionamiento institucional y transformación digital en educación superior, banca central y consultoría internacional. Profesor de posgrado en marketing e IA. Bogotá, Colombia.',
  image = '/assets/img/og-camilo.jpg',
  url = 'https://camiloayala.com'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, url);
---

<!DOCTYPE html>
<html lang="es-CO">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <script is:inline>if(!matchMedia('(prefers-reduced-motion: reduce)').matches)document.documentElement.classList.add('motion');</script>
  <meta name="description" content={description} />
  <meta name="keywords" content="estratega de marca, dirección de marketing, marketing educativo, admisiones, transformación digital, CRM, salesforce, IA, diseño generativo, UX/UI, conferencista, bogotá" />
  <meta name="author" content="Camilo Ayala Monje" />

  <!-- Indexación / rich results (SEO + AEO) -->
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="format-detection" content="telephone=no" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="profile" />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, url).toString()} />
  <meta property="og:image:alt" content="Camilo Ayala Monje — Ejecutivo Senior en Estrategia, Mercadeo y Transformación Digital" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:site_name" content="Camilo Ayala Monje" />
  <meta property="og:locale" content="es_CO" />
  <meta property="profile:first_name" content="Camilo" />
  <meta property="profile:last_name" content="Ayala Monje" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL.toString()} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, url).toString()} />
  <meta property="twitter:image:alt" content="Camilo Ayala Monje — Ejecutivo Senior en Estrategia, Mercadeo y Transformación Digital" />
  <meta property="twitter:site" content="@camiloayalam" />
  <meta property="twitter:creator" content="@camiloayalam" />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.toString()} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Inter:wght@400;500;600&display=swap" /></noscript>

  <!-- LCP image preload -->
  <link rel="preload" as="image" href="/assets/img/camilo-photo.webp" fetchpriority="high" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/CA-logo-ico.png" />
  
  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://camiloayala.com/#camilo",
      "name": "Camilo Ayala Monje",
      "givenName": "Camilo",
      "familyName": "Ayala Monje",
      "description": "Ejecutivo senior con más de 12 años liderando estrategia de marca, mercadeo y transformación digital en educación superior, banca central y consultoría internacional. Magíster en Diseño y profesor de posgrado en marketing e IA en Bogotá, Colombia.",
      "jobTitle": "Ejecutivo Senior en Estrategia de Marca, Mercadeo y Comunicación Digital",
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Director de Estrategia y Mercadeo",
        "occupationLocation": { "@type": "City", "name": "Bogotá" }
      },
      "award": "Ganador del concurso nacional de diseño de la moneda conmemorativa 90 años, Banco de la República (2015)",
      "nationality": { "@type": "Country", "name": "Colombia" },
      "url": "https://camiloayala.com",
      "image": "https://camiloayala.com/assets/img/camilo-photo.webp",
      "sameAs": [
        "https://linkedin.com/in/camiloayalam",
        "https://behance.net/camiloayala",
        "https://orcid.org/0000-0002-3485-718X"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Universidad El Bosque"
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "Universidad de los Andes" },
        { "@type": "CollegeOrUniversity", "name": "Universidad Jorge Tadeo Lozano" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressRegion": "DC",
        "addressCountry": "CO"
      },
      "email": "camiloayalamonje@gmail.com",
      "knowsAbout": [
        "Dirección Estratégica de Marca",
        "Marketing Digital",
        "Marketing Educativo y Admisiones",
        "Comunicación",
        "UX/UI",
        "CRM y Salesforce",
        "Analítica de Datos",
        "Diseño Generativo",
        "IA",
        "Docencia",
        "Design Thinking"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Camilo Ayala Monje — Estrategia, Diseño & Consultoría Ejecutiva",
      "url": "https://camiloayala.com",
      "image": "https://camiloayala.com/assets/img/camilo-photo.webp",
      "email": "camiloayalamonje@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressRegion": "Bogotá D.C.",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.7110,
        "longitude": -74.0721
      },
      "areaServed": ["Colombia", "Latinoamérica"],
      "priceRange": "$$",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Estrategia, Diseño y Consultoría Ejecutiva",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dirección Estratégica de Marca", "description": "Posicionamiento institucional y arquitectura de marca para organizaciones que compiten por autoridad. Del diagnóstico al gobierno de marca." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Growth & Marketing Educativo", "description": "Captación y admisiones para instituciones educativas: embudos, experiencia del candidato y analítica." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transformación Digital & CRM", "description": "SEO, SEM, Salesforce y analítica de datos al servicio de KPIs de negocio." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "UX & Experiencia de Cliente", "description": "Auditorías, rediseños y design systems que alinean la experiencia digital con los objetivos del negocio." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "IA & Diseño Generativo", "description": "Adopción de IA en procesos creativos y de negocio, con respaldo académico e investigación publicada." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Conferencias & Formación Ejecutiva", "description": "Keynotes y workshops para comités directivos y equipos: estrategia, Design Thinking e IA aplicada." } }
        ]
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "@id": "https://camiloayala.com/#profilepage",
      "url": "https://camiloayala.com",
      "name": "Camilo Ayala Monje — Estrategia, Mercadeo y Transformación Digital",
      "inLanguage": "es-CO",
      "mainEntity": { "@id": "https://camiloayala.com/#camilo" },
      "about": { "@id": "https://camiloayala.com/#camilo" }
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://camiloayala.com/#website",
      "url": "https://camiloayala.com",
      "name": "Camilo Ayala Monje",
      "inLanguage": "es-CO",
      "publisher": { "@id": "https://camiloayala.com/#camilo" }
    }
  ]
  </script>
  
  <title>{title}</title>
</head>

<body>
  <slot />
</body>
</html>
