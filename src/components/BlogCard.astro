---
interface Props {
  id: string;
  title: string;
  excerpt: string;
  date: Date;
  tags: string[];
  reactions: number;
  featured?: boolean;
}

const { id, title, excerpt, date, tags, reactions, featured } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const daysAgo = Math.floor((Date.now() - date.getTime()) / (1000 * 60 * 60 * 24));
let dateLabel = formattedDate;
if (daysAgo < 7) {
  if (daysAgo === 0) dateLabel = 'Hoy';
  else if (daysAgo === 1) dateLabel = 'Ayer';
  else dateLabel = `hace ${daysAgo} días`;
} else if (daysAgo < 30) {
  dateLabel = `hace ${Math.floor(daysAgo / 7)} semanas`;
}
---

<a href={`/blog/${id}`} class="li-card rv">
  <div class="li-meta">
    <div class="li-av"></div>
    <div>
      <div class="li-nm">Camilo Ayala Monje, MDes</div>
      <div class="li-dt">{dateLabel}</div>
    </div>
  </div>
  <div class="li-body">
    <strong>{title}</strong>
    <p class="excerpt">{excerpt}</p>
  </div>
  <div class="li-tags">
    {tags.map((tag) => (
      <span class="li-tag">{tag}</span>
    ))}
  </div>
  <div class="li-foot">
    <span class="li-link">Leer más →</span>
    <span class="li-react">👍 {reactions}</span>
  </div>
</a>

<style>
  .li-card {
    background: white;
    padding: 2rem;
    border: 1px solid rgba(13, 11, 9, 0.08);
    border-radius: 0;
    animation: fadeInUp 0.8s ease-out;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .li-card:hover {
    box-shadow: 0 10px 30px rgba(26, 26, 26, 0.08);
    transform: translateY(-4px);
  }

  .li-meta {
    display: flex;
    gap: 1rem;
  }

  .li-av {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #b6903a 0%, #d0a850 100%);
    flex-shrink: 0;
  }

  .li-nm {
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .li-dt {
    font-size: 0.8rem;
    color: rgba(107, 99, 89, 0.8);
  }

  .li-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .li-body strong {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.3;
  }

  .excerpt {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(107, 99, 89, 0.85);
    margin: 0;
  }

  .li-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .li-tag {
    background: rgba(182, 144, 58, 0.08);
    color: var(--gold);
    padding: 0.4rem 0.8rem;
    border-radius: 2px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .li-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(13, 11, 9, 0.08);
    color: rgba(107, 99, 89, 0.8);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .li-link {
    color: var(--gold);
    transition: color 0.2s;
  }

  .li-card:hover .li-link {
    color: var(--goldt);
  }

  .li-react {
    margin-left: auto;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
