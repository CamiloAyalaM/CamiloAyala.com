---
interface Props {
  id: string;
  title: string;
  excerpt: string;
  date: Date;
  tags: string[];
  reactions: number;
  featured?: boolean;
}

const { id, title, excerpt, date, tags, reactions, featured } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const daysAgo = Math.floor((Date.now() - date.getTime()) / (1000 * 60 * 60 * 24));
let dateLabel = formattedDate;
if (daysAgo < 7) {
  if (daysAgo === 0) dateLabel = 'Hoy';
  else if (daysAgo === 1) dateLabel = 'Ayer';
  else dateLabel = `hace ${daysAgo} días`;
} else if (daysAgo < 30) {
  dateLabel = `hace ${Math.floor(daysAgo / 7)} semanas`;
}
---

<a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="li-card rv">
  <div class="li-meta">
    <div class="li-av"><img src="/assets/img/camilo-photo.webp" alt="Camilo Ayala" /></div>
    <div>
      <div class="li-nm">Camilo Ayala Monje, MDes</div>
      <div class="li-dt">{dateLabel}</div>
    </div>
  </div>
  <div class="li-body">
    <h3 class="li-title">{title}</h3>
    <p class="excerpt">{excerpt}</p>
  </div>
  <div class="li-tags">
    {tags.map((tag) => (
      <span class="li-tag">{tag}</span>
    ))}
  </div>
  <div class="li-foot">
    <span class="li-react">👍 {reactions}</span>
  </div>
</a>

