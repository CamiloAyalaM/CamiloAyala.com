---
import BlogCard from '../BlogCard.astro';
import { getFeaturedPosts } from '../../data/blog';

const featuredPosts = getFeaturedPosts().slice(0, 3);
---

<section class="li-sec" id="blog">
  <div class="li-head">
    <div class="rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Blog</span></div>
      <h2 class="sec">Últimas<br><em>publicaciones.</em></h2>
    </div>
    <p class="li-intro rv">Reflexiones sobre diseño estratégico, educación, tecnología e IA. Sígueme en <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">linkedin.com/in/camiloayalam</a> — 5K seguidores y creciendo.</p>
  </div>
  <div class="li-grid">
    {featuredPosts.map((post, i) => (
      <div class="li-card-wrap rv" style={`transition-delay: ${i * 0.09}s`}>
        <BlogCard {...post} />
      </div>
    ))}
  </div>
  <div class="li-banner rv" style="transition-delay:.12s">
    <div class="li-banner-t">
      <h3>¿Hablamos de diseño, tecnología y comunicación?</h3>
      <p>5.000 profesionales ya siguen esta conversación.</p>
    </div>
    <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="li-banner-a">
      <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      Seguir en LinkedIn
    </a>
  </div>
</section>

<style>
  /* ============================================
     BLOG / LINKEDIN
  ============================================ */
  .li-sec {
    padding: 124px var(--edge);
    background: var(--cream);
  }
  .li-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 88px;
    margin-bottom: 68px;
    align-items: end;
  }
  .li-intro { font-size: 15.5px; line-height: 1.85; color: var(--fg2); }
  .li-intro a {
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid var(--gold25);
    transition: border-color .2s;
  }
  .li-intro a:hover { border-color: var(--gold); }
  .li-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .li-card-wrap { display: contents; }
  .li-banner {
    margin-top: 44px;
    border: 1px solid var(--gold25);
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: white;
  }
  .li-banner-t h3 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 5px;
  }
  .li-banner-t p { font-size: 13.5px; color: var(--muted); }
  .li-banner-a {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .11em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--gold);
    padding: 14px 30px;
    text-decoration: none;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 11px;
    transition: background .2s, transform .18s;
    flex-shrink: 0;
  }
  .li-banner-a:hover { background: var(--goldt); transform: translateY(-1px); }
  .li-banner-a svg { width: 14px; height: 14px; fill: var(--ink); }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1140px) {
    .li-sec { padding-left: 32px; padding-right: 32px; }
  }
  @media (max-width: 1024px) {
    .li-head { grid-template-columns: 1fr; gap: 24px; }
    .li-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .li-sec { padding: 80px 20px; }
    .li-grid { grid-template-columns: 1fr; }
    .li-banner { flex-direction: column; align-items: flex-start; }
  }
</style>
