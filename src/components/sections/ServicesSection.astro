---
import { services } from '../../data/portfolio';
---

<section class="services-sec" id="servicios">
  <div class="srv-head">
    <div class="rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Servicios</span></div>
      <h2 class="sec">Dónde genero<br><em>valor.</em></h2>
    </div>
    <p class="srv-intro rv">Asesoría de nivel directivo: combino visión estratégica, diseño y herramientas de IA para que organizaciones, instituciones y marcas crezcan con intención — con resultados medibles sobre la mesa.</p>
  </div>
  <div class="srv-grid">
    {services.map((srv, i) => (
      <div class="srv-card rv" style={`--rv-delay: ${i * 0.07}s`}>
        <div class="srv-n">{srv.number}</div>
        <h3 class="srv-title">{srv.title}</h3>
        <div class="srv-desc">{srv.description}</div>
        <div class="srv-tags">
          {srv.tags.map(tag => <span class="srv-tag">{tag}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* ============================================
     SERVICES — claro, tarjetas limpias con aire
  ============================================ */
  .services-sec {
    padding: 140px var(--edge);
    background: var(--bg);
  }
  .srv-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 80px;
    align-items: end;
  }
  .srv-intro { font-size: 19px; line-height: 1.6; color: var(--fg2); }
  .srv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .srv-card {
    background: var(--bg2);
    border-radius: 22px;
    padding: 40px 36px;
    position: relative;
    overflow: hidden;
    transition:
      opacity var(--rv-op) var(--ease-rv) var(--rv-delay, 0s),
      translate var(--rv-mv) var(--ease-rv) var(--rv-delay, 0s),
      transform .35s cubic-bezier(.22,1,.36,1),
      background .28s;
  }
  .srv-card:hover {
    transform: translateY(-6px);
    background: #eeeef0;
  }
  /* Numeral monumental, dorado muy sutil */
  .srv-n {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 600;
    line-height: 1;
    color: var(--gold);
    margin-bottom: 28px;
    letter-spacing: 0.02em;
  }
  .srv-title {
    font-family: var(--display);
    font-size: 25px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 12px;
    line-height: 1.15;
  }
  .srv-desc {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--fg2);
    margin-bottom: 22px;
  }
  .srv-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .srv-tag {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--muted);
    background: rgba(0, 0, 0, 0.04);
    border-radius: 980px;
    padding: 5px 12px;
  }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1140px) {
    .services-sec { padding-left: 28px; padding-right: 28px; }
  }
  @media (max-width: 1024px) {
    .srv-head { grid-template-columns: 1fr; gap: 28px; }
    .srv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .services-sec { padding: 90px 22px; }
    .srv-grid { grid-template-columns: 1fr; }
  }
</style>
