---
import { services } from '../../data/portfolio';
---

<section class="services-sec" id="servicios">
  <div class="srv-head">
    <div class="rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Servicios</span></div>
      <h2 class="sec dk">Lo que puedo<br>hacer por <em>ti.</em></h2>
    </div>
    <p class="srv-intro rv">Combino visión estratégica, expertise en diseño y herramientas de IA para ayudar a organizaciones y profesionales a comunicar con autoridad y crecer con intención.</p>
  </div>
  <div class="srv-grid">
    {services.map((srv, i) => (
      <div class="srv-card rv" style={`transition-delay: ${i * 0.07}s`}>
        <div class="srv-n">{srv.number}</div>
        <h3 class="srv-title">{srv.title}</h3>
        <div class="srv-desc">{srv.description}</div>
        <div class="srv-tags">
          {srv.tags.map(tag => <span class="srv-tag">{tag}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* ============================================
     SERVICES
  ============================================ */
  .services-sec {
    padding: 124px var(--edge);
    background: var(--ink);
  }
  .srv-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 88px;
    margin-bottom: 64px;
  }
  .srv-intro { font-size: 15.5px; line-height: 1.85; color: rgba(218,208,192,.62); padding-top: 10px; }
  .srv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(244,240,232,.05);
  }
  .srv-card {
    background: var(--ink);
    padding: 42px 38px;
    position: relative;
    overflow: hidden;
    transition: background .28s;
  }
  .srv-card:hover { background: var(--ink2); }
  .srv-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0;
    background: var(--gold);
    transition: height .42s ease;
  }
  /* On scroll-reveal: bar grows to a teaser 40px, inviting hover */
  .srv-card.in::before {
    height: 40px;
    transition: height 0.6s cubic-bezier(.25,.46,.45,.94) 0.3s;
  }
  /* On hover: complete the bar (override the reveal delay) */
  .srv-card:hover::before {
    height: 100%;
    transition: height .42s ease 0s;
  }
  .srv-n { font-family: var(--mono); font-size: 10px; letter-spacing: .14em; color: var(--gold); margin-bottom: 22px; }
  .srv-title { font-family: var(--serif); font-size: 23px; font-weight: 600; color: rgba(244,240,232,.97); margin-bottom: 11px; }
  .srv-desc {
    font-size: 14px;
    line-height: 1.8;
    color: rgba(244,240,232,.86);
    font-weight: 500;
    margin-bottom: 16px;
  }
  .srv-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .srv-tag {
    font-family: var(--mono);
    font-size: 8.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(182,144,58,.52);
    border: 1px solid rgba(182,144,58,.18);
    padding: 3px 8px;
  }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1140px) {
    .services-sec { padding-left: 32px; padding-right: 32px; }
  }
  @media (max-width: 1024px) {
    .srv-head { grid-template-columns: 1fr; gap: 24px; }
    .srv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .services-sec { padding: 80px 20px; }
    .srv-grid { grid-template-columns: 1fr; }
  }
</style>
