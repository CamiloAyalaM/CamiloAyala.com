---
import { portfolioProjects, clients } from '../../data/portfolio';

const featuredProjects = portfolioProjects.filter(p => p.featured);
---

<section class="portfolio-sec" id="portafolio">
  <div class="port-head">
    <div class="rv-l">
      <div class="s-tag"><div class="s-line"></div><span class="s-txt">Portafolio</span></div>
      <h2 class="sec dk">Proyectos<br>con <em>impacto.</em></h2>
    </div>
    <p class="port-intro rv">Proyectos que he dirigido para marcas globales e instituciones de referencia, con métricas verificables: campañas de millones de impresiones, exposiciones nacionales e investigación publicada.</p>
  </div>
  <div class="port-grid">
    {featuredProjects.map((project, i) => (
      <div class={`pc rv pc-${project.gridSize}`} style={`transition-delay: ${i * 0.06}s`}>
        <div class="pc-img">
          <img class="pc-bg" src={project.image} alt={`${project.title} — ${project.client}`} loading="lazy" />
          <div class="pc-over">
            <div class="pc-cat">{project.category}</div>
            <div class="pc-title">{project.title}</div>
          </div>
        </div>
        <div class="pc-desc">
          <div class="pc-metric">{project.metrics}</div>
          <div class="pc-role">{project.description}</div>
          <div class="pc-date">{project.client} · {project.year}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<div class="clients-sec">
  <div class="cl-hd rv">Organizaciones con las que he trabajado</div>
  <div class="cl-grid">
    {clients.map((client, i) => (
      <div class="cl-item rv" style={`transition-delay: ${i * 0.04}s`}>
        <div class="cl-logo" style={`background: ${client.bg}`}>
          <img src={client.logo} alt={client.name} loading="lazy" style={client.scale ? `transform: scale(${client.scale})` : ''} />
        </div>
        <span class="cl-name">{client.name}</span>
      </div>
    ))}
  </div>
</div>

<style>
  /* ============================================
     PORTFOLIO — showcase oscuro, tarjetas grandes
  ============================================ */
  .portfolio-sec {
    padding: 150px var(--edge);
    background: var(--dark);
    position: relative;
    z-index: 0;
  }
  .port-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 80px;
    align-items: end;
  }
  .port-intro { font-size: 19px; line-height: 1.6; color: var(--don2); }
  .port-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 28px;
  }
  .pc {
    position: relative;
    cursor: default;
    display: flex;
    flex-direction: column;
  }
  .pc-lg { grid-column: span 7; }
  .pc-sm { grid-column: span 5; }
  .pc-md { grid-column: span 6; }
  .pc-img {
    width: 100%;
    aspect-ratio: 16/11;
    overflow: hidden;
    position: relative;
    border-radius: 22px;
    background: var(--dark2);
  }
  .pc-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform .8s cubic-bezier(.25,.46,.45,.94);
  }
  .pc:hover .pc-bg { transform: scale(1.05); }
  .pc-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.78) 0%, rgba(0,0,0,.12) 48%, transparent 100%);
  }
  .pc-over {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 30px;
    z-index: 2;
  }
  .pc-cat {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--goldt);
    margin-bottom: 8px;
  }
  .pc-title {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--don);
    line-height: 1.12;
  }
  .pc-desc {
    padding: 22px 4px 0;
  }
  .pc-metric {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--goldt);
    margin-bottom: 8px;
  }
  .pc-role { font-size: 15.5px; color: var(--don2); line-height: 1.6; margin-bottom: 10px; }
  .pc-date {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    color: rgba(245, 245, 247, 0.4);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* ============================================
     CLIENTS — claro, logos en círculos
  ============================================ */
  .clients-sec {
    padding: 110px var(--edge);
    background: var(--bg2);
  }
  .cl-hd {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 52px;
    text-align: center;
  }
  .cl-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }
  .cl-item {
    background: var(--bg);
    border-radius: 22px;
    padding: 32px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    transition: transform .3s cubic-bezier(.22,1,.36,1);
    min-height: 168px;
  }
  .cl-item:hover { transform: translateY(-5px); }
  .cl-logo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 8px;
  }
  .cl-logo img { width: 100%; height: 100%; object-fit: contain; }
  .cl-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-align: center;
    line-height: 1.38;
    transition: color .22s;
  }
  .cl-item:hover .cl-name { color: var(--fg); }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1140px) {
    .portfolio-sec, .clients-sec { padding-left: 28px; padding-right: 28px; }
  }
  @media (max-width: 1024px) {
    .port-head { grid-template-columns: 1fr; gap: 28px; }
    .cl-grid { grid-template-columns: repeat(5, 1fr); }
  }
  @media (max-width: 768px) {
    .portfolio-sec { padding: 90px 22px; }
    .clients-sec { padding: 80px 22px; }
    .port-grid { grid-template-columns: 1fr; gap: 36px; }
    .pc-lg, .pc-sm, .pc-md { grid-column: span 1; }
    .cl-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
