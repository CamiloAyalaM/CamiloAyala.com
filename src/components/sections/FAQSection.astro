---
import { faqs } from '../../data/faq';

// FAQPage schema generado del mismo array que la lista visible: nunca se
// desincronizan. AEO/Google requieren que las respuestas existan en el HTML.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://camiloayala.com/#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<section class="faq-sec" id="faq">
  <div class="faq-head rv-l">
    <div class="s-tag"><div class="s-line"></div><span class="s-txt">FAQ</span></div>
    <h2 class="sec">Preguntas<br><em>frecuentes.</em></h2>
  </div>
  <div class="faq-list">
    {faqs.map((f, i) => (
      <details class="faq-item rv" style={`--rv-delay: ${i * 0.05}s`}>
        <summary class="faq-q">
          <span>{f.question}</span>
          <span class="faq-ic" aria-hidden="true"></span>
        </summary>
        <div class="faq-a"><p>{f.answer}</p></div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-sec {
    padding: 140px var(--edge);
    background: var(--bg);
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 80px;
    align-items: start;
  }
  .faq-head { position: sticky; top: 120px; }

  .faq-list {
    border-top: 1px solid var(--line);
  }
  .faq-item {
    border-bottom: 1px solid var(--line);
    transition:
      opacity var(--rv-op) var(--ease-rv) var(--rv-delay, 0s),
      translate var(--rv-mv) var(--ease-rv) var(--rv-delay, 0s);
  }
  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 26px 4px;
    cursor: pointer;
    list-style: none;
    font-family: var(--display);
    font-size: clamp(18px, 1.9vw, 22px);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--fg);
    transition: color 0.2s;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-item:hover .faq-q { color: var(--gold); }

  /* Icono + / × que rota al abrir */
  .faq-ic {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .faq-ic::before,
  .faq-ic::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    background: var(--gold);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-ic::before { width: 16px; height: 1.5px; transform: translate(-50%, -50%); }
  .faq-ic::after { width: 1.5px; height: 16px; transform: translate(-50%, -50%); }
  .faq-item[open] .faq-ic::after { transform: translate(-50%, -50%) scaleY(0); }
  .faq-item[open] .faq-ic::before { transform: translate(-50%, -50%) rotate(180deg); }

  .faq-a {
    overflow: hidden;
    padding: 0 60px 28px 4px;
  }
  .faq-a p {
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--fg2);
    max-width: 60ch;
  }
  /* Fade-in del contenido al abrir */
  .faq-item[open] .faq-a p {
    animation: faq-reveal 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes faq-reveal {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    .faq-sec { grid-template-columns: 1fr; gap: 44px; }
    .faq-head { position: static; }
  }
  @media (max-width: 768px) {
    .faq-sec { padding: 90px 22px; }
    .faq-a { padding-right: 24px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-ic::before, .faq-ic::after,
    .faq-item[open] .faq-a p { animation: none; transition: none; }
  }
</style>
