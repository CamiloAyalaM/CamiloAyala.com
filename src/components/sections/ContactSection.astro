<section class="cta-sec" id="contacto">
  <div class="cta-l rv-l">
    <div class="s-tag"><div class="s-line"></div><span class="s-txt">Contacto</span></div>
    <h2 class="sec">Trabajemos<br><em>juntos.</em></h2>
    <p class="cta-body">Asesoro a directivos, instituciones y marcas en estrategia de posicionamiento, crecimiento y transformación digital, y dicto conferencias y formación ejecutiva. Hablemos de tu próximo reto.</p>
  </div>
  <div class="cta-r rv">
    <div class="cta-links">
      <a href="mailto:camiloayalamonje@gmail.com" class="cta-link">
        <span>Email directo</span>
        <div class="cta-meta">
          <span class="cta-badge">Disponible</span>
          <span class="cta-arr">&rarr;</span>
        </div>
      </a>
      <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="cta-link">
        <span>LinkedIn</span>
        <div class="cta-meta">
          <span class="cta-badge">5K+</span>
          <span class="cta-arr">&rarr;</span>
        </div>
      </a>
      <a href="https://behance.net/camiloayala" target="_blank" rel="noopener" class="cta-link">
        <span>Behance</span>
        <div class="cta-meta">
          <span class="cta-arr">&rarr;</span>
        </div>
      </a>
      <a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener" class="cta-link">
        <span>ORCID</span>
        <div class="cta-meta">
          <span class="cta-arr">&rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

<footer class="footer">
  <a href="/" class="f-logo"><img src="/assets/img/camilo-ayala.webp" alt="Camilo Ayala" width="600" height="160" /></a>
  <p class="f-copy">&copy; 2025 Camilo Ayala Monje &middot; Bogotá, Colombia</p>
  <ul class="f-links">
    <li><a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener">LinkedIn</a></li>
    <li><a href="https://behance.net/camiloayala" target="_blank" rel="noopener">Behance</a></li>
    <li><a href="https://orcid.org/0000-0002-3485-718X" target="_blank" rel="noopener">ORCID</a></li>
  </ul>
</footer>

<style>
  /* ============================================
     CTA — cierre amplio, lista de enlaces grande
  ============================================ */
  .cta-sec {
    padding: 160px var(--edge);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    background: var(--bg);
  }
  .cta-body {
    font-size: 19px;
    line-height: 1.6;
    color: var(--fg2);
    margin-top: 28px;
    max-width: 440px;
  }
  .cta-links { display: flex; flex-direction: column; }
  .cta-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--display);
    font-size: 30px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--fg);
    text-decoration: none;
    transition: color .22s, padding-left .28s;
  }
  .cta-link:first-child { border-top: 1px solid var(--line); }
  .cta-link:hover { color: var(--gold); padding-left: 10px; }
  .cta-meta { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .cta-badge {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--gold);
    background: var(--gold08);
    border-radius: 980px;
    padding: 4px 13px;
  }
  .cta-arr {
    font-family: var(--sans);
    font-size: 18px;
    color: var(--muted);
    transition: color .22s, transform .28s;
  }
  .cta-link:hover .cta-arr { color: var(--gold); transform: translateX(5px); }
  /* One-shot pulse on each arrow when the contact column enters viewport */
  .cta-r.in .cta-link:nth-child(1) .cta-arr { animation: arr-pulse 1.2s ease 0.50s 1; }
  .cta-r.in .cta-link:nth-child(2) .cta-arr { animation: arr-pulse 1.2s ease 0.65s 1; }
  .cta-r.in .cta-link:nth-child(3) .cta-arr { animation: arr-pulse 1.2s ease 0.80s 1; }
  .cta-r.in .cta-link:nth-child(4) .cta-arr { animation: arr-pulse 1.2s ease 0.95s 1; }

  /* ============================================
     FOOTER — claro, sobrio
  ============================================ */
  .footer {
    padding: 40px var(--edge);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg2);
    border-top: 1px solid var(--line);
  }
  .f-logo img { height: 22px; width: auto; opacity: .45; transition: opacity .22s; }
  .f-logo:hover img { opacity: .8; }
  .f-copy { font-family: var(--sans); font-size: 12px; color: var(--muted); letter-spacing: 0; }
  .f-links { display: flex; gap: 26px; list-style: none; }
  .f-links a {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--muted);
    text-decoration: none;
    transition: color .22s;
  }
  .f-links a:hover { color: var(--fg); }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1140px) {
    .cta-sec { padding-left: 28px; padding-right: 28px; }
  }
  @media (max-width: 1024px) {
    .cta-sec { grid-template-columns: 1fr; gap: 44px; }
  }
  @media (max-width: 768px) {
    .cta-sec { padding: 100px 22px; }
    .footer { flex-direction: column; gap: 16px; text-align: center; padding: 32px 22px; }
  }
</style>
