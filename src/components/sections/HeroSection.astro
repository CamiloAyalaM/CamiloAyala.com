---
import { highlights } from '../../data/portfolio';
---

<section class="hero" id="inicio">
  <div class="hero-photo"></div>
  <div class="hero-left">
    <div class="eyebrow">
      <span class="ey-dash"></span>
      <span class="ey-txt">Ejecutivo Senior — Estrategia · Mercadeo · Transformación Digital</span>
    </div>
    <h1 class="h1">
      Liderazgo<br>
      que <em>transforma</em><br>
      instituciones.
    </h1>
    <p class="hero-desc">
      <strong>Ejecutivo senior en estrategia de marca, mercadeo y comunicación digital.</strong>
      Más de 12 años liderando posicionamiento institucional y transformación digital en
      educación superior, banca central y consultoría internacional.
    </p>
    <div class="hero-btns">
      <a href="#contacto" class="btn-g">Hablemos &rarr;</a>
      <a href="https://linkedin.com/in/camiloayalam" target="_blank" rel="noopener" class="btn-o">
        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Seguir en LinkedIn
      </a>
    </div>
    <div class="hero-scope" aria-label="Áreas de liderazgo">
      <span>Transformación Digital &amp; IA</span>
      <span>Dirección de Equipos</span>
      <span>Posicionamiento Institucional</span>
    </div>
  </div>
</section>

<div class="mq-wrap" aria-hidden="true">
  <div class="mq-track">
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Universidad de los Andes</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Banco de la República</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Universidad El Bosque</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Marriott Rewards</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Nokia USA</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">NOBOX</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">MUZO Emerald</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">U. Sergio Arboleda</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Colegio Marymount</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">IPES Bogotá</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">ESEIT</span></div>
    <!-- duplicate for seamless loop -->
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Universidad de los Andes</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Banco de la República</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Universidad El Bosque</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Marriott Rewards</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Nokia USA</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">NOBOX</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">MUZO Emerald</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">U. Sergio Arboleda</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">Colegio Marymount</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">IPES Bogotá</span></div>
    <div class="mq-item"><span class="mq-dot"></span><span class="mq-txt">ESEIT</span></div>
  </div>
</div>

<div class="highlights">
  {highlights.map((h, i) => (
    <div class="hl rv" style={`transition-delay: ${i * 0.09}s`}>
      <div class="hl-n">{h.number}</div>
      <div class="hl-l">{h.label}</div>
    </div>
  ))}
</div>

<style>
  /* ============================================
     MARQUEE — cinta de instituciones, limpia sobre claro
  ============================================ */
  .mq-wrap {
    border-bottom: 1px solid var(--line);
    padding: 26px 0;
    overflow: hidden;
    background: var(--bg);
    position: relative;
    z-index: 5;
  }
  .mq-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: scroll-mq 40s linear infinite;
    will-change: transform;
  }
  .mq-item {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 0 22px;
    white-space: nowrap;
  }
  .mq-dot {
    width: 3px;
    height: 3px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
    opacity: .55;
  }
  .mq-txt {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--muted);
  }

  /* ============================================
     HIGHLIGHTS — cifras grandes sobre fondo claro
  ============================================ */
  .highlights {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--bg);
    padding: 96px var(--edge);
    gap: 48px 32px;
  }
  .hl {
    text-align: center;
  }
  .hl-n {
    font-family: var(--display);
    font-size: clamp(48px, 5.6vw, 84px);
    font-weight: 600;
    color: var(--fg);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .hl-n sup { font-size: .45em; vertical-align: super; color: var(--gold); }
  .hl-l {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--muted);
    margin-top: 14px;
    line-height: 1.5;
    white-space: pre-line;
  }

  /* ============================================
     RESPONSIVE
  ============================================ */
  @media (max-width: 1024px) {
    .highlights { grid-template-columns: repeat(2, 1fr); gap: 56px 24px; }
  }
  @media (max-width: 768px) {
    .highlights { padding: 72px 22px; gap: 44px 20px; }
  }
</style>
