---
---

<nav id="nav">
  <a href="/" class="nav-logo">
    <img src="/assets/img/camilo-ayala.webp" alt="Camilo Ayala" width="600" height="160" />
  </a>
  <ul class="nav-links">
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#sobre">Sobre mí</a></li>
    <li><a href="#portafolio">Portafolio</a></li>
    <li><a href="#blog">Blog</a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#contacto">Contacto</a></li>
  </ul>
  <a href="#contacto" class="nav-cta">Hablemos</a>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px var(--edge);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid transparent;
    transition: padding 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.4s ease, background 0.4s ease;
  }

  nav.compact {
    padding: 11px var(--edge);
    border-bottom: 1px solid var(--line);
  }

  .nav-logo img {
    height: 24px;
    width: auto;
    transition: opacity 0.25s;
  }

  .nav-logo:hover img {
    opacity: 0.6;
  }

  .nav-links {
    display: flex;
    gap: 34px;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg2);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }

  .nav-cta {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #fff;
    background: var(--fg);
    padding: 8px 18px;
    border-radius: 980px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    cursor: pointer;
    border: none;
  }

  .nav-cta:hover {
    background: #000;
    transform: scale(1.03);
  }

  @media (max-width: 1024px) {
    .nav-links {
      gap: 24px;
    }
    .nav-links a {
      font-size: 12px;
    }
  }

  @media (max-width: 768px) {
    nav {
      padding: 9px var(--edge);
    }

    /* En mobile el menú desaparece: queda logo + CTA en barra compacta */
    .nav-links {
      display: none;
    }

    .nav-logo img {
      height: 20px;
    }

    .nav-cta {
      padding: 7px 15px;
      font-size: 12px;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const COMPACT_THRESHOLD = 140; // ~2x nav height, avoids forced reflow from offsetHeight
  let isCompact = false;

  document.addEventListener('scroll', () => {
    const shouldBeCompact = window.scrollY > COMPACT_THRESHOLD;
    if (shouldBeCompact !== isCompact) {
      nav?.classList.toggle('compact', shouldBeCompact);
      isCompact = shouldBeCompact;
    }
  }, { passive: true });
</script>
